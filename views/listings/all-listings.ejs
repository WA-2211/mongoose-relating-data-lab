<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Listings</title>
</head>
<body>
    <h1>All Listings</h1>
    <% for(let oneListing of listings){ %>
    
        <p>Street Address: <%= oneListing.streetAddress%></p>
        <p> City: <%= oneListing.city%></p>
        <p>Price: <%= oneListing.price%></p>
        <p>Size: <%= oneListing.size%></p>
        <p>Owner: <%= oneListing.owner.username%></p>

    <% } %>
</body>
</html>