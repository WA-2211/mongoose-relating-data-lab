<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Listing</title>
</head>
<body>
    <h1>Edit Listing</h1>

      <form action="/listings/<%= listing._id %>/?_method=PUT" method="post">

        <label for="streetAddress">Street Address:</label>
        <input type="text" name="streetAddress" id="streetAddress" value="<%= listing.streetAddress %>">

        <label for="city">City:</label>
        <input type="text" name="city" id="city" value="<%= listing.city %>">

        <label for="price">Price</label>
        <input type="number" name="price" id="price" value="<%= listing.price %>">

        <label for="size">Size:</label>
        <input type="number" name="size" id="size" value="<%= listing.size %>">

        <label for="owner">Owner</label>
        <select name="owner" id="owner">
            <% for(let oneOwner of owners){ %>
                <option value="<%= oneOwner._id %>" <% if(oneOwner._id.equals(listing.owner._id)){%>
                    selected
                    <%}%>
                    <%= oneOwner.username %></option>
            <% } %>
        </select>
        <button type="submit">Edit Listing</button>
    </form>

    <form action="/listings/<%= listing._id %>/?_method=DELETE" method="post">
        <button type="submit" class="btnSubmit">Delete Listing</button>
    </form>

</body>
</html>